# ローカル用: このファイルをコピーして `.env.local` を作り、値を埋めてください。
# Next.js が `.env.local` を読み込み、Route Handler（例: `app/api/feedback`, `app/api/chat`）から参照されます。
# 環境変数を変えたあとは `pnpm dev` を再起動してください。

# ---- AI チャット（OpenRouter。任意。未設定だと docs 内検索チャットは利用不可）----
OPENROUTER_API_KEY=

# ---- Feedback → GitHub Issue（任意。トークンとリポジトリの両方をセットで有効）----
# fine-grained PAT など。Issues の書き込み権限が必要です。
DOCS_FEEDBACK_GITHUB_TOKEN=
# 例: haya-inc/shindanshi
DOCS_FEEDBACK_GITHUB_REPO=
# 任意。リポジトリに既存のラベル名をカンマ区切り（例: docs,feedback）
DOCS_FEEDBACK_GITHUB_LABELS=

# ---- Feedback → その他（任意）----
# DOCS_FEEDBACK_WEBHOOK_URL=
# 未設定時はプロジェクト直下の data/docs-feedback.jsonl
# DOCS_FEEDBACK_LOG_PATH=
